{"type":"excalidraw","version":2,"source":"https://app.excalidraw.com","appState":{"viewBackgroundColor":"#FFF","lockedMultiSelections":{}},"elements":[{"id":"-0YK_l0O1NRqjP9bm1DYC","type":"line","x":25398,"y":7448,"width":362,"height":92,"strokeColor":"#868e96","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":1763401985,"version":38,"versionNonce":2094118170,"index":"a0","isDeleted":false,"groupIds":[],"frameId":"1-w5kuo3hrOWnrNGbbx2D","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"points":[[0,0],[362,92]],"startBinding":null,"endBinding":null,"startArrowhead":null,"endArrowhead":null,"polygon":false},{"id":"sco33ve1cdIloDwynddJg","type":"text","x":24026,"y":9040,"width":685.9999999999999,"height":32.199999999999996,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":388198639,"version":38,"versionNonce":1756170202,"index":"a000000000G","isDeleted":false,"groupIds":[],"frameId":"fyTKNEt_YHxpJ-jIHBJFY","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":28,"fontFamily":5,"text":"Linear attention: reorder the multiplication","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Linear attention: reorder the multiplication","autoResize":true,"lineHeight":1.15},{"id":"fyTKNEt_YHxpJ-jIHBJFY","type":"frame","x":23970,"y":9000,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":1834440129,"version":45,"versionNonce":174815942,"index":"a000000000V","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"presenterNotes":"* The trick: replace softmax with a feature map \u03c6 (e.g. elu+1). Then (Q K\u1d40) V can be regrouped.\n* Standard:  softmax(Q K\u1d40) V   \u2192   cost O(N\u00b2 d).\n* Linear:   \u03c6(Q) ( \u03c6(K)\u1d40 V )   \u2192   cost O(N d\u00b2).\n* The softmax forced the N\u00d7N matrix. Remove it, and matrix associativity lets you flip the order.\n* Trade-off: often weaker quality on small N. Big wins on long sequences.","slidesOrder":16},"name":"Linear attention: reorder the multiplication"},{"id":"hJHXGuEiC2cK20tPAbTM5","type":"text","x":22760,"y":9254,"width":59.080000000000005,"height":17.5,"strokeColor":"#868e96","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":1691132367,"version":38,"versionNonce":1077083290,"index":"a000000001","isDeleted":false,"groupIds":[],"frameId":"iNhXYsqsoBrpW4T2JWgGj","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":14,"fontFamily":5,"text":"n = 100","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"n = 100","autoResize":true,"lineHeight":1.25},{"id":"nsknrpOGHju_FiIa6ziQl","type":"line","x":22760,"y":9170,"width":70,"height":70,"strokeColor":"#868e96","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":534216481,"version":37,"versionNonce":1308373510,"index":"a000000002","isDeleted":false,"groupIds":[],"frameId":"iNhXYsqsoBrpW4T2JWgGj","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"points":[[0,0],[70,70]],"startBinding":null,"endBinding":null,"startArrowhead":null,"endArrowhead":null,"polygon":false},{"id":"lGkxrCZoRGRft8AHeNXTm","type":"text","x":22716,"y":9040,"width":613.4399999999998,"height":41.4,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":1842463745,"version":38,"versionNonce":1151097178,"index":"a000000004","isDeleted":false,"groupIds":[],"frameId":"iNhXYsqsoBrpW4T2JWgGj","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":36,"fontFamily":5,"text":"The N\u00b2 problem with attention","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"The N\u00b2 problem with attention","autoResize":true,"lineHeight":1.15},{"id":"iNhXYsqsoBrpW4T2JWgGj","type":"frame","x":22660,"y":9000,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":1122222159,"version":45,"versionNonce":619970886,"index":"a000000008","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"presenterNotes":"* Standard attention computes an N\u00d7N matrix of similarity scores between every pair of tokens.\n* Memory and compute both scale as N\u00b2 in sequence length.\n* A 2000-token paragraph is fine. A 200k-token book is not. A million-token codebase is hopeless.\n* This is the bottleneck linear attention tries to fix.","slidesOrder":15},"name":"The N\u00b2 problem with attention"},{"id":"LmKig8CCjuO9tII1nABRD","type":"arrow","x":25460.5,"y":8382,"width":29,"height":0,"strokeColor":"#1971c2","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":0,"opacity":100,"angle":0,"seed":495424769,"version":5,"versionNonce":2059685284,"index":"a00000000G","isDeleted":false,"groupIds":[],"frameId":"ZzNl8dJEj2KxoGhke4wjI","boundElements":[],"updated":1781871584517,"link":null,"locked":false,"points":[[0,0],[29,0]],"startBinding":{"elementId":"94bdN9wYBvxFmWEdXSbbg","mode":"inside","fixedPoint":[1,0.5001]},"endBinding":{"elementId":"07crWZzW02wGTiLs2m0BN","mode":"inside","fixedPoint":[0,0.5001]},"startArrowhead":null,"endArrowhead":"arrow","elbowed":false},{"id":"706R3dOC4fBM55PQf50VZ","type":"text","x":25336,"y":8150,"width":770.6399999999998,"height":29.9,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":2026052719,"version":40,"versionNonce":1430003226,"index":"a00000000V","isDeleted":false,"groupIds":[],"frameId":"ZzNl8dJEj2KxoGhke4wjI","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":26,"fontFamily":5,"text":"BERT and GPT: two halves of the same Transformer","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"BERT and GPT: two halves of the same Transformer","autoResize":true,"lineHeight":1.15},{"id":"94bdN9wYBvxFmWEdXSbbg","type":"rectangle","x":25380,"y":8350,"width":80,"height":64,"strokeColor":"#1971c2","backgroundColor":"#d0ebff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":{"type":3},"roughness":0,"opacity":100,"angle":0,"seed":1687162017,"version":6,"versionNonce":263387428,"index":"a00000001","isDeleted":false,"groupIds":[],"frameId":"ZzNl8dJEj2KxoGhke4wjI","boundElements":[{"id":"PIx02Ok10kFnNqpYeRHhh","type":"text"},{"id":"LmKig8CCjuO9tII1nABRD","type":"arrow"}],"updated":1781871584517,"link":null,"locked":false},{"id":"ZzNl8dJEj2KxoGhke4wjI","type":"frame","x":25280,"y":8110,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":568764847,"version":45,"versionNonce":1118824582,"index":"a00000002","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"presenterNotes":"* The original Transformer had an encoder (reads the whole input) and a decoder (generates output step by step).\n* BERT (2018) drops the decoder \u2014 it's encoder-only, and learns by masking words and predicting them.\n* GPT (2018) drops the encoder \u2014 it's decoder-only, and learns by predicting the next token.\n* Same building block, two very different objectives.","slidesOrder":14},"name":"BERT and GPT: two halves of the same Transformer"},{"id":"L-oJqIg82YJxv68NxmSCF","type":"arrow","x":24130.5,"y":8370,"width":39,"height":0,"angle":0,"strokeColor":"#868e96","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":"AVeBSYqfMJpgoxKq8Nqc8","index":"a00000004","roundness":null,"seed":647252321,"version":5,"versionNonce":2025862308,"isDeleted":false,"boundElements":[],"updated":1781871584517,"link":null,"locked":false,"points":[[0,0],[39,0]],"startBinding":{"elementId":"NU_kCoF_-yD2_Kxf2__RS","mode":"inside","fixedPoint":[1,0.5001]},"endBinding":{"elementId":"g-azRV1IasCsS9u8bXt4U","mode":"inside","fixedPoint":[0,0.5001]},"startArrowhead":null,"endArrowhead":"arrow","elbowed":false},{"id":"NU_kCoF_-yD2_Kxf2__RS","type":"rectangle","x":24030,"y":8330,"width":100,"height":80,"angle":0,"strokeColor":"#fa5252","backgroundColor":"#fff5f5","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":"AVeBSYqfMJpgoxKq8Nqc8","index":"a00000008","roundness":{"type":3},"seed":1278500769,"version":6,"versionNonce":436590492,"isDeleted":false,"boundElements":[{"type":"text","id":"tiw7YR5JlExSrLe76ujPD"},{"id":"L-oJqIg82YJxv68NxmSCF","type":"arrow"}],"updated":1781871584517,"link":null,"locked":false},{"id":"koJVZ36khSlOAcxQuLGnb","type":"text","x":24026,"y":8150,"width":367.2,"height":41.4,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":982724623,"version":40,"versionNonce":1862617818,"index":"a0000000G","isDeleted":false,"groupIds":[],"frameId":"AVeBSYqfMJpgoxKq8Nqc8","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":36,"fontFamily":5,"text":"The pivot problem","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"The pivot problem","autoResize":true,"lineHeight":1.15},{"id":"AVeBSYqfMJpgoxKq8Nqc8","type":"frame","x":23970,"y":8110,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":1452789921,"version":45,"versionNonce":1726801862,"index":"a0000000V","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"presenterNotes":"* Before multilingual Transformers, Google Translate trained a separate model per language pair.\n* For N languages that is N(N\u22121)/2 models \u2014 so for 100 languages, almost 5,000.\n* To save work, every non-English pair was translated by pivoting through English: ZH \u2192 EN \u2192 JA.\n* Each hop compounds errors, and the meaning drifts.\n* Multilingual Transformer models (Johnson et al., 2016/2017) train ONE model on all language pairs,\n  prefixed with a target-language token. The model learns to translate directly between any pair.","slidesOrder":13},"name":"Why old Google Translate went via English"},{"id":"hEGRUdnQS1Vg4bme4TAdD","type":"ellipse","x":23408,"y":8508,"width":24,"height":24,"angle":0,"strokeColor":"#e8590c","backgroundColor":"#ffffff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":"GFX8QRRi3BTnOpgOPs7kx","index":"a0000001","roundness":null,"seed":1025193807,"version":6,"versionNonce":1479433124,"isDeleted":false,"boundElements":[{"id":"XPGSbq6s0UyEX4vHCHTmU","type":"arrow"}],"updated":1781871584517,"link":null,"locked":false},{"id":"he_gwqqek0PF8Vqk5rTRx","type":"text","x":22716,"y":8150,"width":383.03999999999996,"height":43.699999999999996,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":1830924961,"version":40,"versionNonce":2022367130,"index":"a0000002","isDeleted":false,"groupIds":[],"frameId":"GFX8QRRi3BTnOpgOPs7kx","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":38,"fontFamily":5,"text":"Where this landed","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Where this landed","autoResize":true,"lineHeight":1.15},{"id":"GFX8QRRi3BTnOpgOPs7kx","type":"frame","x":22660,"y":8110,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":116450223,"version":46,"versionNonce":1372061446,"index":"a0000004","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"presenterNotes":"* The Transformer was adopted in production by Google Translate around 2018\u20132019.\n* It became the default backbone for translation quality across hundreds of language pairs.\n* The same architecture also spread to BERT (2018), GPT (2018), T5 (2019), and most modern LLMs.","slidesOrder":12},"name":"Where this landed: Google Translate"},{"id":"99WHXBHuWTu6ZStxXcXam","type":"text","x":25336,"y":7680,"width":588.3000000000004,"height":18.75,"strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":1524419361,"version":40,"versionNonce":234871898,"index":"a0000008","isDeleted":false,"groupIds":[],"frameId":"1-w5kuo3hrOWnrNGbbx2D","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":15,"fontFamily":5,"text":"every word of a long sentence must fit through one fixed-size vector","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"every word of a long sentence must fit through one fixed-size vector","autoResize":true,"lineHeight":1.25},{"id":"kRVLo5BSG5nzghNFKO07S","type":"line","x":25760,"y":7448,"width":198,"height":92,"strokeColor":"#868e96","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":1337873007,"version":40,"versionNonce":935210566,"index":"a000000G","isDeleted":false,"groupIds":[],"frameId":"1-w5kuo3hrOWnrNGbbx2D","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"points":[[0,0],[-198,92]],"startBinding":null,"endBinding":null,"startArrowhead":null,"endArrowhead":null,"polygon":false},{"id":"-hPj45nbbH3GZ41-gPBpx","type":"line","x":25360,"y":5745.5,"width":800,"height":79.8,"strokeColor":"#e8590c","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":699953761,"version":41,"versionNonce":1295466778,"index":"a000000V","isDeleted":false,"groupIds":[],"frameId":"mbLs_9K-9SWWw_PpFDyc4","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"points":[[0,0],[10,54.4],[20,-4.199999999999999],[30,-9.8],[40,53.5],[50,6.4],[60,-17.700000000000003],[70,49.4],[80,17.6],[90,-23.1],[100,42.6],[110,28.7],[120,-25.4],[130,33.6],[140,38.6],[150,-24.6],[160,23],[170,46.5],[180,-20.6],[190,11.7],[200,51.9],[210,-13.899999999999999],[220,0.6999999999999993],[230,54.4],[240,-4.899999999999999],[250,-9.3],[260,53.6],[270,5.699999999999999],[280,-17.3],[290,49.8],[300,16.9],[310,-22.799999999999997],[320,43.1],[330,28],[340,-25.4],[350,34.2],[360,38],[370,-24.700000000000003],[380,23.7],[390,46.1],[400,-21],[410,12.4],[420,51.7],[430,-14.399999999999999],[440,1.3000000000000007],[450,54.3],[460,-5.5],[470,-8.7],[480,53.8],[490,5],[500,-16.9],[510,50.1],[520,16.2],[530,-22.6],[540,43.6],[550,27.3],[560,-25.299999999999997],[570,34.8],[580,37.4],[590,-24.9],[600,24.3],[610,45.7],[620,-21.299999999999997],[630,13.1],[640,51.4],[650,-14.899999999999999],[660,2],[670,54.3],[680,-6.100000000000001],[690,-8.100000000000001],[700,53.9],[710,4.300000000000001],[720,-16.4],[730,50.4],[740,15.5],[750,-22.299999999999997],[760,44.1],[770,26.7],[780,-25.200000000000003],[790,35.4],[800,36.8]],"startBinding":null,"endBinding":null,"startArrowhead":null,"endArrowhead":null,"polygon":false},{"id":"rZHrApJEjLGnM7e_-uHjk","type":"rectangle","x":26080,"y":7420,"width":76,"height":56,"angle":0,"strokeColor":"#1971c2","backgroundColor":"#d0ebff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":"1-w5kuo3hrOWnrNGbbx2D","index":"a000001","roundness":{"type":3},"seed":340668271,"version":5,"versionNonce":827772452,"isDeleted":false,"boundElements":[{"type":"text","id":"-LkSarIJdHCJfyuSqJx1P"}],"updated":1781871584517,"link":null,"locked":false},{"id":"4g0rt7jHoIbYDdA-phSQ1","type":"text","x":25336,"y":7260,"width":498.2400000000001,"height":41.4,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":287640687,"version":40,"versionNonce":900494726,"index":"a000002","isDeleted":false,"groupIds":[],"frameId":"1-w5kuo3hrOWnrNGbbx2D","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":36,"fontFamily":5,"text":"Why the bottleneck hurts","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Why the bottleneck hurts","autoResize":true,"lineHeight":1.15},{"id":"1-w5kuo3hrOWnrNGbbx2D","type":"frame","x":25280,"y":7220,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":354701889,"version":47,"versionNonce":564399578,"index":"a000004","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"presenterNotes":"* One vector c has to summarize the whole input sentence.\n* Long or complex sentences lose information in that squeeze.\n* Long-range dependencies \u2014 word A at the start matters for word Z at the end \u2014 are hard to preserve.","slidesOrder":11},"name":"Why the bottleneck hurts"},{"id":"L626CLuzmNYzHdJSFbsAw","type":"text","x":24026,"y":7260,"width":804.7199999999998,"height":32.199999999999996,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":1453417871,"version":40,"versionNonce":1154471110,"index":"a000008","isDeleted":false,"groupIds":[],"frameId":"2Gdk2bMzzjsc_LEF6PtYe","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":28,"fontFamily":5,"text":"How prior models solved it: encoder\u2013decoder RNN","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"How prior models solved it: encoder\u2013decoder RNN","autoResize":true,"lineHeight":1.15},{"id":"Zrwb0WOVX7kvZjA6ZBHy8","type":"arrow","x":24094.5,"y":7512,"width":27,"height":0,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":"2Gdk2bMzzjsc_LEF6PtYe","index":"a00000G","roundness":null,"seed":639856609,"version":5,"versionNonce":1141675300,"isDeleted":false,"boundElements":[],"updated":1781871584517,"link":null,"locked":false,"points":[[0,0],[27,0]],"startBinding":{"elementId":"sMerhh2zq-zh4IMNh7Ulk","mode":"inside","fixedPoint":[1,0.5001]},"endBinding":{"elementId":"APeXqHzQtpbqDR-sOkXU0","mode":"inside","fixedPoint":[0,0.5001]},"startArrowhead":null,"endArrowhead":"arrow","elbowed":false},{"id":"sMerhh2zq-zh4IMNh7Ulk","type":"rectangle","x":24030,"y":7480,"width":64,"height":64,"angle":0,"strokeColor":"#1971c2","backgroundColor":"#d0ebff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":"2Gdk2bMzzjsc_LEF6PtYe","index":"a00000V","roundness":{"type":3},"seed":1233494543,"version":6,"versionNonce":1083031324,"isDeleted":false,"boundElements":[{"type":"text","id":"Babw-rK6E285uLLKE9kKW"},{"id":"Zrwb0WOVX7kvZjA6ZBHy8","type":"arrow"}],"updated":1781871584517,"link":null,"locked":false},{"id":"2Gdk2bMzzjsc_LEF6PtYe","type":"frame","x":23970,"y":7220,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":162594465,"version":48,"versionNonce":274285210,"index":"a00001","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"presenterNotes":"* Before 2017, the dominant approach was an encoder\u2013decoder RNN.\n* The encoder reads the source one token at a time and emits a single context vector c.\n* The decoder then generates the target one token at a time, conditioned on c.","slidesOrder":10},"name":"How prior models solved it"},{"id":"5H6RqrGbkY1F_mwTHtyLY","type":"text","x":22716,"y":7260,"width":535.0400000000001,"height":36.8,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":624091407,"version":40,"versionNonce":784681990,"index":"a00002","isDeleted":false,"groupIds":[],"frameId":"Ij7zzZbZMBB23T3C6uyVN","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":32,"fontFamily":5,"text":"The task: machine translation","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"The task: machine translation","autoResize":true,"lineHeight":1.15},{"id":"8lF6L8XNPVLCCzLX1M3-D","type":"rectangle","x":22720,"y":7440,"width":320,"height":100,"angle":0,"strokeColor":"#1971c2","backgroundColor":"#e7f5ff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":"Ij7zzZbZMBB23T3C6uyVN","index":"a00004","roundness":{"type":3},"seed":283359297,"version":6,"versionNonce":2067569700,"isDeleted":false,"boundElements":[{"type":"text","id":"jVCDhhU5LREaANcRSqJM1"},{"id":"B_cd8fCx-ML3pXWe9BjR5","type":"arrow"}],"updated":1781871584517,"link":null,"locked":false},{"id":"Ij7zzZbZMBB23T3C6uyVN","type":"frame","x":22660,"y":7220,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":566964463,"version":49,"versionNonce":67755866,"index":"a00008","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"presenterNotes":"* The paper targets machine translation: given text in one language, produce the same meaning in another.\n* This slide sets the stage before any architecture is on the table.\n* Translation is hard: word order, idioms, gender, ambiguity \u2014 all must be resolved from context.","slidesOrder":9},"name":"The task"},{"id":"X5bwR2Ysglk-R-Fkh2mU0","type":"text","x":23540,"y":5040,"width":50.120000000000005,"height":17.5,"strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":500030502,"version":41,"versionNonce":25811782,"index":"a0000G","isDeleted":false,"groupIds":[],"frameId":"krs2gsair-WFbBog8aWYu","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":18,"fontFamily":5,"text":"1 / 17","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"1 / 17","autoResize":true,"lineHeight":1.25},{"id":"D67kwZ9-RrtUG3ohWERRc","type":"rectangle","x":25360,"y":6710,"width":130,"height":54,"angle":0,"strokeColor":"#1971c2","backgroundColor":"#d0ebff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":"fVuTW3HMR2fyY_SggbEJN","index":"a0000V","roundness":{"type":3},"seed":536517734,"version":5,"versionNonce":458376348,"isDeleted":false,"boundElements":[{"type":"text","id":"xHK1sk46c7J0T3HOntyw9"}],"updated":1781871584517,"link":null,"locked":false},{"id":"sGw-WhPADpmQ-0NmaduTr","type":"text","x":25336,"y":6370,"width":328.00000000000006,"height":46,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":334528358,"version":40,"versionNonce":420013082,"index":"a0001","isDeleted":false,"groupIds":[],"frameId":"fVuTW3HMR2fyY_SggbEJN","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":40,"fontFamily":5,"text":"Why it matters","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Why it matters","autoResize":true,"lineHeight":1.15},{"id":"fVuTW3HMR2fyY_SggbEJN","type":"frame","x":25280,"y":6330,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":1151232122,"version":50,"versionNonce":58360454,"index":"a0002","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"presenterNotes":"The Transformer dropped recurrence, becoming the base for BERT, GPT, T5, ViT, and every modern LLM.","slidesOrder":8},"name":"Why it matters"},{"id":"dL5wcAKCGvpRFh3Kl-qC6","type":"text","x":24026,"y":6370,"width":172.79999999999998,"height":46,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":1265006842,"version":40,"versionNonce":1766412506,"index":"a0004","isDeleted":false,"groupIds":[],"frameId":"3sZNg0IhbTrM2u0YInPP-","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":40,"fontFamily":5,"text":"Results","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Results","autoResize":true,"lineHeight":1.15},{"id":"3sZNg0IhbTrM2u0YInPP-","type":"frame","x":23970,"y":6330,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":707902758,"version":51,"versionNonce":659833286,"index":"a0008","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"slidesOrder":7},"name":"Results"},{"id":"NYKddIJ8KEE4uGzSYrp3X","type":"arrow","x":22865,"y":6572.5,"width":0,"height":15,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":"z592mGguePyV_XGB_R0WS","index":"a000G","roundness":null,"seed":592329537,"version":5,"versionNonce":1422617124,"isDeleted":false,"boundElements":[],"updated":1781871584517,"link":null,"locked":false,"points":[[0,0],[0,15]],"startBinding":{"elementId":"Yn_N8Kry2ix8_K-ZKdT4r","mode":"inside","fixedPoint":[0.5001,1]},"endBinding":{"elementId":"oR5xrJBTq4oqgxgU1e3OG","mode":"inside","fixedPoint":[0.5001,0]},"startArrowhead":null,"endArrowhead":"arrow","elbowed":false},{"id":"e6krT6YKuM0FljvFx_pm3","type":"text","x":23220,"y":6480,"width":119.51999999999997,"height":20.7,"strokeColor":"#e8590c","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":33145089,"version":40,"versionNonce":1482565018,"index":"a000V","isDeleted":false,"groupIds":[],"frameId":"z592mGguePyV_XGB_R0WS","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":18,"fontFamily":5,"text":"Decoder \u00d76","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Decoder \u00d76","autoResize":true,"lineHeight":1.15},{"id":"Yn_N8Kry2ix8_K-ZKdT4r","type":"rectangle","x":22780,"y":6520,"width":170,"height":52,"angle":0,"strokeColor":"#1971c2","backgroundColor":"#d0ebff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":"z592mGguePyV_XGB_R0WS","index":"a001","roundness":{"type":3},"seed":1144820225,"version":6,"versionNonce":1134724516,"isDeleted":false,"boundElements":[{"type":"text","id":"Z5i7OIuuXMi2TrpwJm8d9"},{"id":"NYKddIJ8KEE4uGzSYrp3X","type":"arrow"}],"updated":1781871584517,"link":null,"locked":false},{"id":"bJ4QxVYojdv3Y_cLWeOZw","type":"text","x":22716,"y":6370,"width":520.7999999999998,"height":34.5,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":1174715617,"version":40,"versionNonce":3414278,"index":"a002","isDeleted":false,"groupIds":[],"frameId":"z592mGguePyV_XGB_R0WS","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":30,"fontFamily":5,"text":"The Transformer architecture","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"The Transformer architecture","autoResize":true,"lineHeight":1.15},{"id":"z592mGguePyV_XGB_R0WS","type":"frame","x":22660,"y":6330,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":2042236271,"version":52,"versionNonce":1601856090,"index":"a004","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"presenterNotes":"* Encoder: N=6 identical layers, each = self-attention + positionwise FFN, with residual+LayerNorm.\n* Decoder: N=6 layers, each = masked self-attention + cross-attention (K,V from encoder) + FFN.\n* Masking keeps positions from attending to the future; cross-attention reads the encoder output.","slidesOrder":6},"name":"The Transformer architecture"},{"id":"3gr5H2EhHjSRPaeWvRQGU","type":"line","x":25360,"y":5741.1,"width":800,"height":55.5,"strokeColor":"#6741d9","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":867254863,"version":41,"versionNonce":899090502,"index":"a008","isDeleted":false,"groupIds":[],"frameId":"mbLs_9K-9SWWw_PpFDyc4","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"points":[[0,0],[10,15.599999999999998],[20,42.099999999999994],[30,-8.100000000000001],[40,31.099999999999998],[50,30],[60,-7.800000000000001],[70,42.7],[80,14.499999999999998],[90,0.7999999999999972],[100,46.9],[110,0.3999999999999986],[120,15.099999999999998],[130,42.4],[140,-8],[150,30.599999999999998],[160,30.5],[170,-8],[180,42.4],[190,14.999999999999998],[200,0.5],[210,46.9],[220,0.6999999999999993],[230,14.7],[240,42.599999999999994],[250,-7.900000000000002],[260,30.2],[270,30.9],[280,-8.100000000000001],[290,42.2],[300,15.499999999999998],[310,0.09999999999999787],[320,46.9],[330,1.0999999999999979],[340,14.2],[350,42.9],[360,-7.700000000000003],[370,29.7],[380,31.4],[390,-8.200000000000003],[400,41.9],[410,15.999999999999998],[420,-0.3000000000000007],[430,46.9],[440,1.5],[450,13.7],[460,43.099999999999994],[470,-7.600000000000001],[480,29.299999999999997],[490,31.799999999999997],[500,-8.3],[510,41.599999999999994],[520,16.5],[530,-0.6000000000000014],[540,46.9],[550,1.8999999999999986],[560,13.2],[570,43.4],[580,-7.400000000000002],[590,28.799999999999997],[600,32.3],[610,-8.5],[620,41.3],[630,17],[640,-1],[650,46.8],[660,2.299999999999997],[670,12.7],[680,43.599999999999994],[690,-7.200000000000003],[700,28.299999999999997],[710,32.7],[720,-8.600000000000001],[730,41],[740,17.5],[750,-1.3000000000000007],[760,46.8],[770,2.6999999999999993],[780,12.2],[790,43.8],[800,-7]],"startBinding":null,"endBinding":null,"startArrowhead":null,"endArrowhead":null,"polygon":false},{"id":"0enUqAYwJ1jD-TrnrjSx2","type":"rectangle","x":24050,"y":4780,"width":120,"height":100,"strokeColor":"#868e96","backgroundColor":"#f1f3f5","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":{"type":3},"roughness":1,"opacity":100,"angle":0,"seed":162329999,"version":6,"versionNonce":1500540068,"index":"a00G","isDeleted":false,"groupIds":[],"frameId":"ojYNZbveDw7OF8iUw-uTc","boundElements":[{"id":"I9IkGyJQonm4EHLnSRFtu","type":"text"},{"id":"6b6xvvObYTkoeNeK-jkzQ","type":"arrow"}],"updated":1781871584517,"link":null,"locked":false},{"id":"naQchwhBcOHC5zfrdtRWE","type":"line","x":25360,"y":5760,"width":800,"height":140,"strokeColor":"#1971c2","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":3,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":2120552431,"version":40,"versionNonce":1500579610,"index":"a00V","isDeleted":false,"groupIds":[],"frameId":"mbLs_9K-9SWWw_PpFDyc4","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"points":[[0,0],[10,-33.6],[20,-58.9],[30,-69.8],[40,-63.7],[50,-41.9],[60,-9.9],[70,24.6],[80,53],[90,68.4],[100,67.1],[110,49.4],[120,19.6],[130,-15.1],[140,-46],[150,-65.7],[160,-69.3],[170,-55.9],[180,-28.8],[190,5.3],[200,38.1],[210,61.6],[220,70],[230,61.3],[240,37.6],[250,4.6],[260,-29.4],[270,-56.3],[280,-69.3],[290,-65.4],[300,-45.5],[310,-14.5],[320,20.2],[330,49.8],[340,67.3],[350,68.3],[360,52.6],[370,24],[380,-10.5],[390,-42.4],[400,-63.9],[410,-69.8],[420,-58.6],[430,-33],[440,0.6],[450,34.1],[460,59.2],[470,69.9],[480,63.4],[490,41.4],[500,9.3],[510,-25.1],[520,-53.4],[530,-68.6],[540,-66.9],[550,-48.9],[560,-19],[570,15.7],[580,46.5],[590,65.9],[600,69.2],[610,55.5],[620,28.3],[630,-5.9],[640,-38.6],[650,-61.9],[660,-70],[670,-61],[680,-37],[690,-4],[700,30],[710,56.6],[720,69.4],[730,65.2],[740,45],[750,13.8],[760,-20.7],[770,-50.3],[780,-67.5],[790,-68.2],[800,-52.2]],"startBinding":null,"endBinding":null,"startArrowhead":null,"endArrowhead":null,"polygon":false},{"id":"T3d2_kmMGo1knXJGqjDkN","type":"line","x":25350,"y":5760,"width":810,"height":0,"strokeColor":"#868e96","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":550725313,"version":40,"versionNonce":2002390918,"index":"a01","isDeleted":false,"groupIds":[],"frameId":"mbLs_9K-9SWWw_PpFDyc4","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"points":[[0,0],[810,0]],"startBinding":null,"endBinding":null,"startArrowhead":null,"endArrowhead":null,"polygon":false},{"id":"mbLs_9K-9SWWw_PpFDyc4","type":"frame","x":25280,"y":5440,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":323297487,"version":55,"versionNonce":1320489946,"index":"a02","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"presenterNotes":"* Self-attention is permutation-invariant \u2014 it has no sense of order.\n* Add a sinusoidal encoding to the embeddings so positions are distinguishable.\n* Sines/cosines of different frequencies let the model attend by relative position.","slidesOrder":5},"name":"Positional encoding"},{"id":"CVX9PMMKjA0NFBowqFff4","type":"frame","x":23970,"y":5440,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":984730342,"version":57,"versionNonce":1908027078,"index":"a04","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"presenterNotes":"* Instead of one attention on d_model, run h=8 heads in parallel on d_k=d_v=64.\n* Each head can learn a different relationship (e.g. syntactic vs semantic).\n* Concatenate the heads and project back to d_model=512.","slidesOrder":4},"name":"Multi-head: parallel views"},{"id":"45MrRgJOKKV9u2mpQq72r","type":"frame","x":22660,"y":5440,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":625896762,"version":58,"versionNonce":1096386714,"index":"a08","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"presenterNotes":"* Attention maps a query Q to key-value pairs (K,V): output is a weighted sum of values.\n* Weights = softmax( Q\u00b7K\u1d40 ), scaled by 1/\u221ad_k to keep gradients stable when d_k is large.\n* This is the one operation the entire architecture is built from.","slidesOrder":3},"name":"Scaled dot-product attention"},{"id":"6413ZTbDklmMzClULXHyI","type":"frame","x":25280,"y":4550,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":1800380966,"version":58,"versionNonce":1096050182,"index":"a0G","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"presenterNotes":"* Self-attention lets every position look at every other position in a single step.\n* Constant path length between any pair \u2014 long-range dependencies become easy.\n* Fully parallelizable across positions, which is exactly what GPUs exploit.","slidesOrder":2},"name":"Self-attention: everything sees everything"},{"id":"krs2gsair-WFbBog8aWYu","type":"frame","x":22660,"y":4550,"width":960,"height":540,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":816389025,"version":45,"versionNonce":2031183194,"index":"a0V","isDeleted":false,"groupIds":[],"frameId":null,"boundElements":null,"updated":1781871584517,"link":null,"locked":false,"customData":{"presenterNotes":"* Welcome. Today's paper: Vaswani et al., 2017 (NeurIPS).\n* It introduces the Transformer \u2014 the first sequence model built only on attention.\n* This single paper reshaped NLP and underpins every modern LLM.","slidesOrder":0},"name":"Title"},{"id":"-r2det7i_hR2dDp6z4iKU","type":"rectangle","x":22760,"y":9170,"width":70,"height":70,"strokeColor":"#868e96","backgroundColor":"#ffffff","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":{"type":3},"roughness":0,"opacity":100,"angle":0,"seed":1679636623,"version":36,"versionNonce":1730524486,"index":"a1","isDeleted":false,"groupIds":[],"frameId":"iNhXYsqsoBrpW4T2JWgGj","boundElements":null,"updated":1781871584517,"link":null,"locked":false},{"id":"5yOU1ogMBACcorwMHmDpY","type":"text","x":24839.865451388887,"y":9490,"width":59.36000000000001,"height":17.5,"strokeColor":"#495057","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roundness":null,"roughness":1,"opacity":100,"angle":0,"seed":798414817,"version":38,"versionNonce":1328523802,"index":"a1000001","isDeleted":false,"groupIds":[],"frameId":"fyTKNEt_YHxpJ-jIHBJFY","boundElements":null,"updated":1781871584517,"link":null,"locked":false,"fontSize":18,"fontFamily":5,"text":"17 / 17","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"17 / 17","autoResize":true,"lineHeight":1.25},{"id":"uJ-idjWzwXQpelbuzUWB4","type":"rectang