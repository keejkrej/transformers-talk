[{"type": "frame", "tempId": "s11", "name": "How prior models solved it", "x": 14200, "y": 100, "width": 960, "height": 540, "customData": {"presenterNotes": "* Before 2017, the dominant approach was an encoder\u2013decoder RNN.\n* The encoder reads the source one token at a time and emits a single context vector c.\n* The decoder then generates the target one token at a time, conditioned on c."}}, {"type": "text", "x": 14256, "y": 140, "width": 848, "height": 40, "text": "How prior models solved it: encoder\u2013decoder RNN", "fontSize": 28, "fontFamily": 7, "strokeColor": "#1e1e1e", "frameId": "s11"}, {"type": "rectangle", "tempId": "e0", "x": 14260, "y": 360, "width": 64, "height": 64, "backgroundColor": "#d0ebff", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s11", "label": {"text": "x1", "fontSize": 18, "fontFamily": 7}}, {"type": "rectangle", "tempId": "e1", "x": 14352, "y": 360, "width": 64, "height": 64, "backgroundColor": "#d0ebff", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s11", "label": {"text": "x2", "fontSize": 18, "fontFamily": 7}}, {"type": "rectangle", "tempId": "e2", "x": 14444, "y": 360, "width": 64, "height": 64, "backgroundColor": "#d0ebff", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s11", "label": {"text": "x3", "fontSize": 18, "fontFamily": 7}}, {"type": "rectangle", "tempId": "e3", "x": 14536, "y": 360, "width": 64, "height": 64, "backgroundColor": "#d0ebff", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s11", "label": {"text": "x4", "fontSize": 18, "fontFamily": 7}}, {"type": "arrow", "x": 14324, "y": 392.0, "width": 28, "height": 0, "points": [[0, 0], [28, 0]], "endArrowhead": "arrow", "roughness": 0, "strokeColor": "#1e1e1e", "frameId": "s11", "startBinding": {"elementId": "e0", "fixedPoint": [1, 0.5], "mode": "in