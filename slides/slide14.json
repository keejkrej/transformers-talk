[{"type": "frame", "tempId": "s14", "name": "Why old Google Translate went via English", "x": 18430, "y": 100, "width": 960, "height": 540, "customData": {"presenterNotes": "* Before multilingual Transformers, Google Translate trained a separate model per language pair.\n* For N languages that is N(N\u22121)/2 models \u2014 so for 100 languages, almost 5,000.\n* To save work, every non-English pair was translated by pivoting through English: ZH \u2192 EN \u2192 JA.\n* Each hop compounds errors, and the meaning drifts.\n* Multilingual Transformer models (Johnson et al., 2016/2017) train ONE model on all language pairs,\n  prefixed with a target-language token. The model learns to translate directly between any pair."}}, {"type": "text", "x": 18486, "y": 140, "width": 848, "height": 48, "text": "The pivot problem", "fontSize": 36, "fontFamily": 7, "strokeColor": "#1e1e1e", "frameId": "s14"}, {"type": "text", "x": 18490, "y": 260, "width": 380, "height": 28, "text": "Old: pivot through English", "fontSize": 18, "fontFamily": 7, "strokeColor": "#fa5252", "frameId": "s14"}, {"type": "rectangle", "tempId": "zh", "x": 18490, "y": 320, "width": 100, "height": 80, "backgroundColor": "#fff5f5", "strokeColor": "#fa5252", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s14", "label": {"text": "ZH", "fontSize": 26, "fontFamily": 7}}, {"type": "rectangle", "tempId": "en1", "x": 18630, "y": 320, "width": 100, "height": 80, "backgroundColor": "#f1f3f5", "strokeColor": "#868e96", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s14", "label": {"text": "EN", "fontSize": 26, "fontFamily": 7}}, {"type": "rectangle", "tempId": "ja", "x": 18770, "y": 320, "width": 100, "height": 80, "backgroundColor": "#fff5f5", "strokeColor": "#fa5252", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s14", "label": {"text": "JA", "fontSize": 26, "fontFamily": 7}}, {"type": "arrow", "x": 18590, "y": 360, "width": 40, "height": 0, "points": [[0, 0], [40, 0]], "endArrowhead": "arrow", "roughness": 0, "strokeColor": "#868e96", "frameId": "s14", "startBinding": {"elementId": "zh", "fixedPoint": [1, 0.5], "mode": "inside"}, "endBinding": {"elementId": "en1", "fixedPoint": [0, 0.5], "mode": "inside"}}, {"type": "arrow", "x": 18730, "y": 360, "width": 40, "height": 0, "points": [[0, 0], [40, 0]], "endArrowhead": "arrow", "roughness": 0, "strokeColor": "#868e96", "frameId": "s14", "startBinding": {"elementId": "en1", "fixedPoint": [1, 0.5], "mode": "inside"}, "endBinding": {"elementId": "ja", "fixedPoint": [0, 0.5], "mode": "inside"}}, {"type": "text", "x": 18490, "y": 420, "width": 380, "height": 24, "text": "two hops \u00b7 errors stack \u00b7 meaning drifts", "fontSize": 13, "fontFamily": 5, "strokeColor": "#495057", "frameId": "s14"}, {"type": "text", "x": 18910, "y": 260, "width": 420, "height": 28, "text": "New: one multilingual model", "fontSize": 18, "fontFamily": 7, "strokeColor": "#0ca678", "frameId": "s14"}, {"type": "rectangle", "tempId": "zh2", "x": 18910, "y": 320, "width": 100, "height": 80, "backgroundColor": "#e6fcf5", "strokeColor": "#0ca678", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s14", "label": {"text": "ZH", "fontSize": 26, "fontFamily": 7}}, {"type": "rectangle", "tempId": "mm", "x": 19070, "y": 320, "width": 140, "height": 80, "backgroundColor": "#f3f0ff", "strokeColor": "#6741d9", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s14", "label": {"text": "multi-\nlingual", "fontSize": 15, "fontFamily": 7}}, {"type": "rectangle", "tempId": "ja2", "x": 19250, "y": 320, "width": 100, "height": 80, "backgroundColor": "#e6fcf5", "strokeColor": "#0ca678", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s14", "label": {"text": "JA", "fontSize": 26, "fontFamily": 7}}, {"type": "arrow", "x": 19010, "y": 360, "width": 60, "height": 0, "points": [[0, 0], [60, 0]], "endArrowhead": "arrow", "roughness": 0, "strokeColor": "#0ca678", "frameId": "s14", "startBinding": {"elementId": "zh2", "fixedPoint": [1, 0.5], "mode": "inside"}, "endBinding": {"elementId": "mm", "fixedPoint": [0, 0.5], "mode": "inside"}}, {"type": "arrow", "x": 19210, "y": 360, "width": 40, "height": 0, "points": [[0, 0], [40, 0]], "endArrowhead": "arrow", "roughness": 0, "strokeColor": "#0ca678", "frameId": "s14", "startBinding": {"elementId": "mm", "fixedPoint": [1, 0.5], "mode": "inside"}, "endBinding": {"elementId": "ja2", "fixedPoint": [0, 0.5], "mode": "inside"}}, {"type": "text", "x": 18910, "y": 420, "width": 420, "height": 24, "text": "one model \u00b7 direct translation \u00b7 no drift", "fontSize": 13, "fontFamily": 5, "strokeColor": "#495057", "frameId": "s14"}, {"type": "rectangle", "tempId": "note", "x": 18490, "y": 510, "width": 840, "height": 60, "backgroundColor": "#fff9db", "strokeColor": "#f08c00", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s14", "label": {"text": "n languages \u2192 one model, not n(n\u22121)/2", "fontSize": 22, "fontFamily": 8}}, {"type": "text", "x": 19300, "y": 590, "width": 60, "height": 22, "text": "14 / 17", "fontSize": 18, "fontFamily": 5, "strokeColor": "#495057", "frameId": "s14"}]