[{"type": "frame", "tempId": "s13", "name": "Where this landed: Google Translate", "x": 17020, "y": 100, "width": 960, "height": 540, "customData": {"presenterNotes": "* The Transformer was adopted in production by Google Translate around 2018\u20132019.\n* It became the default backbone for translation quality across hundreds of language pairs.\n* The same architecture also spread to BERT (2018), GPT (2018), T5 (2019), and most modern LLMs."}}, {"type": "text", "x": 17076, "y": 140, "width": 848, "height": 50, "text": "Where this landed", "fontSize": 38, "fontFamily": 7, "strokeColor": "#1e1e1e", "frameId": "s13"}, {"type": "ellipse", "tempId": "g", "x": 17220, "y": 230, "width": 240, "height": 240, "backgroundColor": "#e7f5ff", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "frameId": "s13", "label": {"text": "G", "fontSize": 120, "fontFamily": 7}}, {"type": "rectangle", "tempId": "hero", "x": 17500, "y": 280, "width": 420, "height": 130, "backgroundColor": "#f3f0ff", "strokeColor": "#6741d9", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s13", "label": {"text": "Transformer in production\nGoogle Translate \u00b7 ~2018", "fontSize": 24, "fontFamily": 7}}, {"type": "arrow", "x": 17220, "y": 510, "width": 560, "height": 0, "points": [[0, 0], [560, 0]], "endArrowhead": "arrow", "roughness": 0, "strokeColor": "#868e96", "frameId": "s13"}, {"type": "ellipse", "tempId": "m0", "x": 17208, "y": 498, "width": 24, "height": 24, "backgroundColor": "#ffffff", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "frameId": "s13"}, {"type": "text", "x": 17170, "y": 530, "width": 120, "height": 50, "text": "2014\nSeq2Seq", "fontSize": 12, "fontFamily": 5, "strokeColor": "#495057", "frameId": "s13"}, {"type": "ellipse", "tempId": "m1", "x": 17488, "y": 498, "width": 24, "height": 24, "backgroundColor": "#ffffff", "strokeColor": "#6741d9", "fillStyle": "solid", "roughness": 0, "frameId": "s13"}, {"type": "text", "x": 17450, "y": 530, "width": 120, "height": 50, "text": "2017\nTransformer", "fontSize": 12, "fontFamily": 5, "strokeColor": "#495057", "frameId": "s13"}, {"type": "ellipse", "tempId": "m2", "x": 17768, "y": 498, "width": 24, "height": 24, "backgroundColor": "#ffffff", "strokeColor": "#e8590c", "fillStyle": "solid", "roughness": 0, "frameId": "s13"}, {"type": "text", "x": 17730, "y": 530, "width": 120, "height": 50, "text": "2018+\nBERT \u00b7 GPT", "fontSize": 12, "fontFamily": 5, "strokeColor": "#495057", "frameId": "s13"}, {"type": "text", "x": 17076, "y": 590, "width": 848, "height": 40, "text": "one paper, then the production stack switches", "fontSize": 16, "fontFamily": 5, "strokeColor": "#495057", "frameId": "s13"}, {"type": "text", "x": 17890, "y": 590, "width": 60, "height": 22, "text": "13 / 17", "fontSize": 18, "fontFamily": 5, "strokeColor": "#495057", "frameId": "s13"}]