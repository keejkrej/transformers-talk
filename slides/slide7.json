[{"type": "frame", "tempId": "s7", "name": "The Transformer architecture", "x": 8560, "y": 100, "width": 960, "height": 540, "customData": {"presenterNotes": "* Encoder: N=6 identical layers, each = self-attention + positionwise FFN, with residual+LayerNorm.\n* Decoder: N=6 layers, each = masked self-attention + cross-attention (K,V from encoder) + FFN.\n* Masking keeps positions from attending to the future; cross-attention reads the encoder output."}}, {"type": "text", "x": 8616, "y": 140, "width": 848, "height": 42, "text": "The Transformer architecture", "fontSize": 30, "fontFamily": 7, "strokeColor": "#1e1e1e", "frameId": "s7"}, {"type": "text", "x": 8680, "y": 250, "width": 170, "height": 28, "text": "Encoder \u00d76", "fontSize": 18, "fontFamily": 7, "strokeColor": "#1971c2", "frameId": "s7"}, {"type": "rectangle", "tempId": "enc_emb", "x": 8680, "y": 290, "width": 170, "height": 52, "backgroundColor": "#d0ebff", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s7", "label": {"text": "Input Embed + PE", "fontSize": 14, "fontFamily": 7}}, {"type": "rectangle", "tempId": "enc_sa", "x": 8680, "y": 358, "width": 170, "height": 52, "backgroundColor": "#e7f5ff", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s7", "label": {"text": "Self-Attention", "fontSize": 14, "fontFamily": 7}}, {"type": "rectangle", "tempId": "enc_ffn", "x": 8680, "y": 426, "width": 170, "height": 52, "backgroundColor": "#f1f3f5", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s7", "label": {"text": "Feed-Forward", "fontSize": 14, "fontFamily": 7}}, {"type": "arrow", "x": 8765.0, "y": 342, "width": 0, "height": 16, "points": [[0, 0], [0, 16]], "endArrowhead": "arrow", "roughness": 0, "strokeColor": "#1e1e1e", "frameId": "s7", "startBinding": {"elementId": "enc_emb", "fixedPoint": [0.5, 1], "mode": "inside"}, "endBinding": {"elementId