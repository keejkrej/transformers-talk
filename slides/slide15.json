[{"type": "frame", "tempId": "s15", "name": "BERT and GPT: two halves of the same Transformer", "x": 19840, "y": 100, "width": 960, "height": 540, "customData": {"presenterNotes": "* The original Transformer had an encoder (reads the whole input) and a decoder (generates output step by step).\n* BERT (2018) drops the decoder \u2014 it's encoder-only, and learns by masking words and predicting them.\n* GPT (2018) drops the encoder \u2014 it's decoder-only, and learns by predicting the next token.\n* Same building block, two very different objectives."}}, {"type": "text", "x": 19896, "y": 140, "width": 848, "height": 38, "text": "BERT and GPT: two halves of the same Transformer", "fontSize": 26, "fontFamily": 7, "strokeColor": "#1e1e1e", "frameId": "s15"}, {"type": "text", "x": 19900, "y": 260, "width": 380, "height": 28, "text": "BERT \u2014 encoder-only", "fontSize": 18, "fontFamily": 7, "strokeColor": "#1971c2", "frameId": "s15"}, {"type": "text", "x": 19900, "y": 300, "width": 380, "height": 22, "text": "reads the whole sentence, both directions", "fontSize": 12, "fontFamily": 5, "strokeColor": "#495057", "frameId": "s15"}, {"type": "rectangle", "tempId": "b0", "x": 19940, "y": 340, "width": 80, "height": 64, "backgroundColor": "#d0ebff", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s15", "label": {"text": "I", "fontSize": 18, "fontFamily": 7}}, {"type": "rectangle", "tempId": "b1", "x": 20050, "y": 340, "width": 80, "height": 64, "backgroundColor": "#fff9db", "strokeColor": "#f08c00", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s15", "label": {"text": "[MASK]", "fontSize": 18, "fontFamily": 7}}, {"type": "rectangle", "tempId": "b2", "x": 20160, "y": 340, "width": 80, "height": 64, "backgroundColor": "#d0ebff", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s15", "label": {"text": "cats", "fontSize": 18, "fontFamily": 7}},