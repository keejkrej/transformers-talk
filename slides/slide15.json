6", "strokeColor": "#e8590c", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s15", "label": {"text": "Once", "fontSize": 18, "fontFamily": 7}}, {"type": "rectangle", "tempId": "g1", "x": 20470, "y": 340, "width": 80, "height": 64, "backgroundColor": "#fff4e6", "strokeColor": "#e8590c", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s15", "label": {"text": "upon", "fontSize": 18, "fontFamily": 7}}, {"type": "rectangle", "tempId": "g2", "x": 20580, "y": 340, "width": 80, "height": 64, "backgroundColor": "#fff4e6", "strokeColor": "#e8590c", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s15", "label": {"text": "a", "fontSize": 18, "fontFamily": 7}}, {"type": "arrow", "x": 20440, "y": 372.0, "width": 30, "height": 0, "points": [[0, 0], [30, 0]], "endArrowhead": "arrow", "roughness": 0, "strokeColor": "#e8590c", "frameId": "s15", "startBinding": {"elementId": "g0", "fixedPoint": [1, 0.5], "mode": "inside"}, "endBinding": {"elementId": "g1", "fixedPoint": [0, 0.5], "mode": "inside"}}, {"type": "arrow", "x": 20550, "y": 372.0, "width": 30, "height": 0, "points": [[0, 0], [30, 0]], "endArrowhead": "arrow", "roughness": 0, "strokeColor": "#e8590c", "frameId": "s15", "startBinding": {"elementId": "g1", "fixedPoint": [1, 0.5], "mode": "inside"}, "endBinding": {"elementId": "g2", "fixedPoint": [0, 0.5], "mode": "inside"}}, {"type": "rectangle", "tempId": "gpred", "x": 20560.0, "y": 444, "width": 120, "height": 56, "backgroundColor": "#e6fcf5", "strokeColor": "#0ca678", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s15", "label": {"text": "time", "fontSize": 22, "fontFamily": 7}}, {"type": "arrow", "x": 20620.0, "y": 404, "width": 0, "height": 40, "points": [[0, 0], [0, 40]], "endArrowhead": "arrow", "roughness": 0, "strokeColor": "#0ca678", "frameId": "s15", "startBinding": {"elementId": "g2", "fixedPoint": [0.5, 1], "mode": "inside"}, "endBinding": {"elementId":