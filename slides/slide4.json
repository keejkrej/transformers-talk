[{"type": "frame", "tempId": "s4", "name": "Scaled dot-product attention", "x": 4330, "y": 100, "width": 960, "height": 540, "customData": {"presenterNotes": "* Attention maps a query Q to key-value pairs (K,V): output is a weighted sum of values.\n* Weights = softmax( Q\u00b7K\u1d40 ), scaled by 1/\u221ad_k to keep gradients stable when d_k is large.\n* This is the one operation the entire architecture is built from."}}, {"type": "text", "x": 4386, "y": 140, "width": 848, "height": 44, "text": "Scaled dot-product attention", "fontSize": 32, "fontFamily": 7, "strokeColor": "#1e1e1e", "frameId": "s4"}, {"type": "rectangle", "tempId": "f4", "x": 4386, "y": 208, "width": 848, "height": 60, "backgroundColor": "#fff9db", "strokeColor": "#f08c00", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s4", "label": {"text": "Attention(Q, K, V) = softmax( Q\u00b7K\u1d40 / \u221ad_k ) \u00b7 V", "fontSize": 22, "fontFamily": 8}}, {"type": "rectangle", "tempId": "a0", "x": 4386, "y": 340, "width": 150, "height": 88, "backgroundColor": "#e7f5ff", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s4", "label": {"text": "Q, K, V", "fontSize": 17, "fontFamily": 7}}, {"type": "rectangle", "tempId": "a1", "x": 4566, "y": 340, "width": 150, "height": 88, "backgroundColor": "#f1f3f5", "strokeColor": "#868e96", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s4", "label": {"text": "MatMul", "fontSize": 17, "fontFamily": 7}}, {"type": "rectangle", "tempId": "a2", "x": 4746, "y": 340, "width": 150, "height": 88, "backgroundColor": "#fff9db", "strokeColor": "#f08c00", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s4", "label": {"text": "Scale\n\u00d71/\u221ad_k", "fontSize": 17, "fontFamily": 7}}, {"type": "rectangle", "tempId": "a3", "x": 4926, "y": 340, "width": 150, "height": 88, "backgroundColor": "#e6fcf5", "strokeColor": "#0ca678", "fillStyle": "solid"