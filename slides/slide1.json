[{"type": "frame", "tempId": "s1", "name": "Title", "x": 100, "y": 100, "width": 960, "height": 540, "customData": {"presenterNotes": "* Welcome. Today's paper: Vaswani et al., 2017 (NeurIPS).\n* It introduces the Transformer \u2014 the first sequence model built only on attention.\n* This single paper reshaped NLP and underpins every modern LLM."}}, {"type": "text", "x": 156, "y": 270, "width": 848, "height": 70, "text": "Attention Is All You Need", "fontSize": 52, "fontFamily": 7, "strokeColor": "#1e1e1e", "frameId": "s1"}, {"type": "line", "x": 156, "y": 350, "width": 848, "height": 0, "points": [[0, 0], [848, 0]], "roughness": 1, "strokeColor": "#1971c2", "strokeWidth": 3, "frameId": "s1"}, {"type": "text", "x": 156, "y": 378, "width": 848, "height": 80, "text": "Vaswani \u00b7 Shazeer \u00b7 Parmar \u00b7 Uszkoreit \u00b7 Jones \u00b7 Gomez \u00b7 Kaiser \u00b7 Polosukhin\nGoogle Brain / Research \u2014 NeurIPS 2017", "fontSize": 17, "fontFamily": 5, "strokeColor": "#495057", "frameId": "s1"}, {"type": "text", "x": 156, "y": 550, "width": 848, "height": 40, "text": "arxiv.org/abs/1706.03762", "fontSize": 16, "fontFamily": 8, "strokeColor": "#868e96", "frameId": "s1"}, {"type": "text", "x": 970, "y": 590, "width": 60, "height": 22, "text": "1 / 17", "fontSize": 18, "fontFamily": 5, "strokeColor": "#495057", "frameId": "s1"}]