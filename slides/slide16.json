[{"type": "frame", "tempId": "s16", "name": "The N\u00b2 problem with attention", "x": 21250, "y": 100, "width": 960, "height": 540, "customData": {"presenterNotes": "* Standard attention computes an N\u00d7N matrix of similarity scores between every pair of tokens.\n* Memory and compute both scale as N\u00b2 in sequence length.\n* A 2000-token paragraph is fine. A 200k-token book is not. A million-token codebase is hopeless.\n* This is the bottleneck linear attention tries to fix."}}, {"type": "text", "x": 21306, "y": 140, "width": 848, "height": 48, "text": "The N\u00b2 problem with attention", "fontSize": 36, "fontFamily": 7, "strokeColor": "#1e1e1e", "frameId": "s16"}, {"type": "rectangle", "tempId": "sq0", "x": 21350, "y": 270, "width": 70, "height": 70, "backgroundColor": "#ffffff", "strokeColor": "#868e96", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s16"}, {"type": "line", "x": 21350, "y": 270, "width": 70, "height": 70, "points": [[0, 0], [70, 70]], "roughness": 1, "strokeColor": "#868e96", "strokeWidth": 2, "frameId": "s16"}, {"type": "text", "x": 21350, "y": 354, "width": 70, "height": 24, "text": "n = 100", "fontSize": 14, "fontFamily": 8, "strokeColor": "#868e96", "frameId": "s16"}, {"type": "rectangle", "tempId": "sq1", "x": 21630, "y": 270, "width": 160, "height": 160, "backgroundColor": "#ffffff", "strokeColor": "#e8590c", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s16"}, {"type": "line", "x": 21630, "y": 270, "width": 160, "height": 160, "points": [[0, 0], [160, 160]], "roughness": 1, "strokeColor": "#e8590c", "strokeWidth": 2, "frameId": "s16"}, {"type": "text", "x": 21630, "y": 444, "width": 160, "height": 24, "text": "n = 1k", "fontSize": 14, "fontFamily": 8, "strokeColor": "#e8590c", "frameId": "s16"}, {"type": "rectangle", "tempId": "sq2", "x": 21910, "y": 270, "width": 260, "height": 260, "backgroundColor": "#ffffff", "strokeColor": "#fa5252", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s16"}, {"type": "line", "x": 21910, "y": 270, "width": 260, "height": 260, "points": [[0, 0], [260, 260]], "roughness": 1, "strokeColor": "#fa5252", "strokeWidth": 2, "frameId": "s16"}, {"type": "text", "x": 21910, "y": 544, "width": 260, "height": 24, "text": "n = 10k", "fontSize": 14, "fontFamily": 8, "strokeColor": "#fa5252", "frameId": "s16"}, {"type": "text", "x": 21350, "y": 560, "width": 260, "height": 24, "text": "10k cells", "fontSize": 16, "fontFamily": 7, "strokeColor": "#868e96", "frameId": "s16"}, {"type": "text", "x": 21630, "y": 560, "width": 260, "height": 24, "text": "1M cells", "fontSize": 16, "fontFamily": 7, "strokeColor": "#e8590c", "frameId": "s16"}, {"type": "text", "x": 21910, "y": 560, "width": 260, "height": 24, "text": "100M cells", "fontSize": 16, "fontFamily": 7, "strokeColor": "#fa5252", "frameId": "s16"}, {"type": "rectangle", "tempId": "takeaway", "x": 21310, "y": 570, "width": 840, "height": 50, "backgroundColor": "#fff9db", "strokeColor": "#f08c00", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s16", "label": {"text": "doubling sequence length = 4\u00d7 the cost of attention", "fontSize": 22, "fontFamily": 8}}, {"type": "text", "x": 22120, "y": 590, "width": 60, "height": 22, "text": "16 / 17", "fontSize": 18, "fontFamily": 5, "strokeColor": "#495057", "frameId": "s16"}]