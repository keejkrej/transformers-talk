[{"type": "frame", "tempId": "s2", "name": "Recurrence is sequential", "x": 1510, "y": 100, "width": 960, "height": 540, "customData": {"presenterNotes": "* Pre-2017 sequence models (RNN/LSTM/GRU) compute hidden states one step at a time.\n* Each state h_t depends on h_{t-1} \u2014 so you cannot process the sequence in parallel.\n* This sequential dependency is the bottleneck the paper attacks."}}, {"type": "text", "x": 1566, "y": 140, "width": 848, "height": 46, "text": "Recurrence is sequential", "fontSize": 34, "fontFamily": 7, "strokeColor": "#1e1e1e", "frameId": "s2"}, {"type": "rectangle", "tempId": "r0", "x": 1590, "y": 330, "width": 120, "height": 100, "backgroundColor": "#f1f3f5", "strokeColor": "#868e96", "fillStyle": "solid", "roughness": 1, "roundness": {"type": 3}, "frameId": "s2", "label": {"text": "h1", "fontSize": 24, "fontFamily": 7}}, {"type": "text", "x": 1590, "y": 442, "width": 120, "height": 28, "text": "x1", "fontSize": 16, "fontFamily": 8, "strokeColor": "#495057", "frameId": "s2"}, {"type": "rectangle", "tempId": "r1", "x": 1760, "y": 330, "width": 120, "height": 100, "backgroundColor": "#f1f3f5", "strokeColor": "#868e96", "fillStyle": "solid", "roughness": 1, "roundness": {"type": 3}, "frameId": "s2", "label": {"text": "h2", "fontSize": 24, "fontFamily": 7}}, {"type": "text", "x": 1760, "y": 442, "width": 120, "height": 28, "text": "x2", "fontSize": 16, "fontFamily": 8, "strokeColor": "#495057", "frameId": "s2"}, {"type": "rectangle", "tempId": "r2", "x": 1930, "y": 330, "width": 120, "height": 100, "backgroundColor": "#f1f3f5", "strokeColor": "#868e96", "fillStyle": "solid", "roughness": 1, "roundness": {"type": 3}, "frameId": "s2", "label": {"text": "h3", "fontSize": 24, "fontFamily": 7}}, {"type": "text", "x": 1930, "y": 442, "width": 120, "height": 28, "text": "x3", "fontSize": 16, "fontFamily": 8, "strokeColor": "#495057", "frameId": "s2"}, {"type": "rectangle", "tempId": "r3", "x": 2100, "y": 330, "width": 120, "height": 100, "backgro