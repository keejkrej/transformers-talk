[{"type": "frame", "tempId": "s17", "name": "Linear attention: reorder the multiplication", "x": 22660, "y": 100, "width": 960, "height": 540, "customData": {"presenterNotes": "* The trick: replace softmax with a feature map \u03c6 (e.g. elu+1). Then (Q K\u1d40) V can be regrouped.\n* Standard:  softmax(Q K\u1d40) V   \u2192   cost O(N\u00b2 d).\n* Linear:   \u03c6(Q) ( \u03c6(K)\u1d40 V )   \u2192   cost O(N d\u00b2).\n* The softmax forced the N\u00d7N matrix. Remove it, and matrix associativity lets you flip the order.\n* Trade-off: often weaker quality on small N. Big wins on long sequences."}}, {"type": "text", "x": 22716, "y": 140, "width": 848, "height": 40, "text": "Linear attention: reorder the multiplication", "fontSize": 28, "fontFamily": 7, "strokeColor": "#1e1e1e", "frameId": "s17"}, {"type": "rectangle", "tempId": "std", "x": 22720, "y": 280, "width": 400, "height": 240, "backgroundColor": "#fff5f5", "strokeColor": "#fa5252", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s17", "label": {"text": "Standard\nsoftmax(Q K\u1d40) V", "fontSize": 22, "fontFamily": 8}}, {"type": "text", "x": 22720, "y": 440, "width": 400, "height": 28, "text": "O(N\u00b2 d)  \u00b7  N\u00d7N matrix", "fontSize": 18, "fontFamily": 7, "strokeColor": "#fa5252", "frameId": "s17"}, {"type": "text", "x": 22720, "y": 480, "width": 400, "height": 22, "text": "softmax forces a full similarity matrix first", "fontSize": 12, "fontFamily": 5, "strokeColor": "#495057", "frameId": "s17"}, {"type": "arrow", "x": 23120, "y": 400, "width": 40, "height": 0, "points": [[0, 0], [40, 0]], "endArrowhead": "arrow", "roughness": 0, "strokeColor": "#1e1e1e", "frameId": "s17"}, {"type": "text", "x": 23100, "y": 370, "width": 80, "height": 28, "text": "reorder", "fontSize": 14, "fontFamily": 8, "strokeColor": "#1e1e1e", "frameId": "s17"}, {"type": "rectangle", "tempId": "lin", "x": 23160, "y": 280, "width": 400, "height": 240, "backgroundColor": "#e6fcf5", "strokeColor": "#0ca678", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s17", "label": {"text": "Linear\n\u03c6(Q) ( \u03c6(K)\u1d40 V )", "fontSize": 22, "fontFamily": 8}}, {"type": "text", "x": 23160, "y": 440, "width": 400, "height": 28, "text": "O(N d\u00b2)  \u00b7  no N\u00d7N matrix", "fontSize": 18, "fontFamily": 7, "strokeColor": "#0ca678", "frameId": "s17"}, {"type": "text", "x": 23160, "y": 480, "width": 400, "height": 22, "text": "(A B) C = A (B C) when shapes match", "fontSize": 12, "fontFamily": 5, "strokeColor": "#495057", "frameId": "s17"}, {"type": "rectangle", "tempId": "note17", "x": 22720, "y": 560, "width": 840, "height": 50, "backgroundColor": "#fff9db", "strokeColor": "#f08c00", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s17", "label": {"text": "remove softmax, exploit associativity, win on long sequences", "fontSize": 20, "fontFamily": 8}}, {"type": "text", "x": 23530, "y": 590, "width": 60, "height": 22, "text": "17 / 17", "fontSize": 18, "fontFamily": 5, "strokeColor": "#495057", "frameId": "s17"}]