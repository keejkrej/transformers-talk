[{"type": "frame", "tempId": "s9", "name": "Why it matters", "x": 11380, "y": 100, "width": 960, "height": 540, "customData": {"presenterNotes": "* The Transformer dropped recurrence, making sequence models parallel and scalable.\n* This became the base architecture for BERT, GPT, T5, ViT and essentially all modern LLMs.\n* 'Attention is all you need' turned out to be one of the most consequential ideas in AI."}}, {"type": "text", "x": 11436, "y": 140, "width": 848, "height": 52, "text": "Why it matters", "fontSize": 40, "fontFamily": 7, "strokeColor": "#1e1e1e", "frameId": "s9"}, {"type": "rectangle", "tempId": "core", "x": 11530, "y": 310, "width": 660, "height": 110, "backgroundColor": "#f3f0ff", "strokeColor": "#6741d9", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s9", "label": {"text": "The foundation of every modern LLM", "fontSize": 30, "fontFamily": 7}}, {"type": "rectangle", "tempId": "c0", "x": 11460, "y": 480, "width": 130, "height": 54, "backgroundColor": "#d0ebff", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s9", "label": {"text": "BERT", "fontSize": 18, "fontFamily": 7}}, {"type": "rectangle", "tempId": "c1", "x": 11605, "y": 480, "width": 130, "height": 54, "backgroundColor": "#d0ebff", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s9", "label": {"text": "GPT", "fontSize": 18, "fontFamily": 7}}, {"type": "rectangle", "tempId": "c2", "x": 11750, "y": 480, "width": 130, "height": 54, "backgroundColor": "#d0ebff", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s9", "label": {"text": "T5", "fontSize": 18, "fontFamily": 7}}, {"type": "rectangle", "tempId": "c3", "x": 11895, "y": 480, "width": 130, "height": 54, "backgroundColor": "#d0ebff", "strokeColor": "#1971c2", "fillStyle": "solid", "roughness": 0, "roundness": {"type": 3}, "frameId": "s9", "label": {"te